<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>I.com - Login</title>

<style>
body{
    background:#111;
    font-family:Arial;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.box{
    width:350px;
    background:#222;
    padding:30px;
    border-radius:20px;
    text-align:center;
    box-shadow:0 0 25px rgba(255,215,0,.4);
}

h1{
    color:gold;
}

input{
    width:90%;
    padding:12px;
    margin:10px;
    border:none;
    border-radius:10px;
}

button{
    width:95%;
    padding:12px;
    background:gold;
    border:none;
    border-radius:10px;
    font-weight:bold;
    cursor:pointer;
}

button:hover{
    transform:scale(1.03);
}

.error{
    color:red;
}

#google_translate_element{
    position:fixed;
    top:10px;
    right:10px;
}
</style>
</head>

<body>

<div id="google_translate_element"></div>

<div class="box">

<h1>I.com</h1>

<p style="color:white;">
Music • Business • Innovation
</p>

<form method="POST">

<input type="text"
name="username"
placeholder="Nom utilisateur"
required>

<input type="password"
name="password"
placeholder="Mot de passe"
required>

<button type="submit">
Connexion
</button>

</form>

<p class="error">{{ message }}</p>

<div style="font-size:50px;margin-top:15px;">
👆
</div>

<p style="color:white;">
Connexion biométrique (à venir)
</p>

</div>

<script>
function googleTranslateElementInit() {
new google.translate.TranslateElement({
pageLanguage:'fr',
includedLanguages:'fr,en,mg'
}, 'google_translate_element');
}
</script>

<script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

</body>
</html>
